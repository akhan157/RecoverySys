{
  "name": "recoverysys",
  "version": "1.2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "tauri:dev": "tauri dev",
    "build": "vite build",
    "tauri:build": "tauri build",
    "portable:package": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-portable.ps1",
    "portable:build": "npm run tauri:build && npm run portable:package",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:narrow": "playwright test e2e/phase1.spec.js",
    "e2e:serve": "npm run build && node scripts/prepare-e2e.mjs && vite preview --host 127.0.0.1 --port 4174",
    "e2e:serve:artifact": "node scripts/prepare-e2e.mjs && vite preview --host 127.0.0.1 --port 4174",
    "check": "npm run format:check && npm run validate:parts && npm run lint && npm test && npm run build",
    "validate:parts": "node scripts/validate-parts.js",
    "lint": "eslint src --max-warnings=0",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\""
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.2.1",
    "ajv": "^8.20.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.10",
    "prettier": "^3.4.0",
    "tailwindcss": "^3.4.1",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  }
}
