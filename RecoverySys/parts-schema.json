{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recoverysys.local/parts-schema.json",
  "title": "RecoverySys static parts catalog",
  "type": "array",
  "items": {
    "$ref": "#/$defs/part"
  },
  "$defs": {
    "positiveNumber": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "nonNegativeNumber": {
      "type": "number",
      "minimum": 0
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "part": {
      "type": "object",
      "required": ["id", "category", "manufacturer", "name", "specs"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "category": {
          "type": "string",
          "enum": [
            "main_chute",
            "drogue_chute",
            "shock_cord",
            "chute_protector",
            "deployment_bag",
            "quick_links",
            "swivel",
            "chute_device"
          ]
        },
        "manufacturer": { "$ref": "#/$defs/nonEmptyString" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "specs": {
          "type": "object",
          "minProperties": 1,
          "properties": {
            "diameter_in": { "$ref": "#/$defs/positiveNumber" },
            "cd": { "$ref": "#/$defs/positiveNumber" },
            "weight_g": { "$ref": "#/$defs/positiveNumber" },
            "packed_diam_in": { "$ref": "#/$defs/positiveNumber" },
            "packed_length_in": { "$ref": "#/$defs/positiveNumber" },
            "shape": { "$ref": "#/$defs/nonEmptyString" },
            "material": { "$ref": "#/$defs/nonEmptyString" },
            "elongation_pct": { "$ref": "#/$defs/positiveNumber" },
            "strength_lbs": { "$ref": "#/$defs/positiveNumber" },
            "length_ft": { "$ref": "#/$defs/positiveNumber" },
            "packed_height_in": { "$ref": "#/$defs/positiveNumber" },
            "width_in": { "$ref": "#/$defs/positiveNumber" },
            "max_chute_diam_in": { "$ref": "#/$defs/positiveNumber" },
            "size_in": { "$ref": "#/$defs/positiveNumber" },
            "rated_lbs": { "$ref": "#/$defs/positiveNumber" },
            "deploy_alt_min_ft": { "$ref": "#/$defs/nonNegativeNumber" },
            "deploy_alt_max_ft": { "$ref": "#/$defs/nonNegativeNumber" }
          },
          "additionalProperties": false,
          "dependentRequired": {
            "deploy_alt_min_ft": ["deploy_alt_max_ft"],
            "deploy_alt_max_ft": ["deploy_alt_min_ft"]
          }
        }
      },
      "additionalProperties": false,
      "allOf": [
        { "if": { "properties": { "category": { "const": "main_chute" } } }, "then": { "properties": { "specs": { "type": "object", "required": ["diameter_in", "cd", "weight_g", "packed_diam_in", "packed_length_in", "shape", "material"] } } } },
        { "if": { "properties": { "category": { "const": "drogue_chute" } } }, "then": { "properties": { "specs": { "type": "object", "required": ["diameter_in", "cd", "weight_g", "packed_diam_in", "packed_length_in", "shape", "material"] } } } },
        { "if": { "properties": { "category": { "const": "shock_cord" } } }, "then": { "properties": { "specs": { "type": "object", "required": ["strength_lbs", "length_ft", "elongation_pct", "material", "weight_g", "packed_height_in", "width_in"] } } } },
        { "if": { "properties": { "category": { "const": "chute_protector" } } }, "then": { "properties": { "specs": { "type": "object", "required": ["size_in", "max_chute_diam_in", "weight_g", "packed_height_in"] } } } },
        { "if": { "properties": { "category": { "const": "deployment_bag" } } }, "then": { "properties": { "specs": { "type": "object", "required": ["max_chute_diam_in", "packed_height_in", "weight_g"] } } } },
        { "if": { "properties": { "category": { "const": "quick_links" } } }, "then": { "properties": { "specs": { "type": "object", "required": ["strength_lbs", "size_in", "weight_g"] } } } },
        { "if": { "properties": { "category": { "const": "swivel" } } }, "then": { "properties": { "specs": { "type": "object", "required": ["rated_lbs", "size_in", "weight_g", "packed_height_in"] } } } },
        { "if": { "properties": { "category": { "const": "chute_device" } } }, "then": { "properties": { "specs": { "type": "object", "required": ["weight_g"] } } } }
      ]
    }
  }
}
